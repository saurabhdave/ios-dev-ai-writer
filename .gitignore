# Secrets
.env

# Virtual environments
.venv/
venv/

# Python caches and build artifacts
__pycache__/
.pycache/
*.py[cod]
*.egg-info/
.pytest_cache/

# macOS
.DS_Store

# Personal editor settings
.vscode/

# Claude Code local tooling & context — kept per-machine, never tracked
.claude/
CLAUDE.md
CLAUDE.local.md
# CLAUDE.md context companions (architecture.md, ci.md, configuration.md, …)
docs/
# Ignore everything under memory/ except files explicitly re-included below.
# Note: must use `memory/*` (contents) not `memory/` (the directory itself) —
# Git cannot un-ignore a file whose parent directory has been excluded.
memory/*
# Persist the topic-family rotation history so CI runs share state.
!memory/family_picks.json

# Generated outputs (published to saurabhdave/ios-ai-articles)
outputs/*
!outputs/quality_history.json
!outputs/quality_history_meta.json
outputs/newsletter/
# Ephemeral per-run summary (written by pipeline, consumed by CI step summary)
outputs/run_summary.json

# Temp content repo clone used by CI publish step
_content/

# Git worktrees
.worktrees/
